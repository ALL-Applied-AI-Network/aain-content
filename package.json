{
  "name": "@all-aain/content",
  "private": true,
  "type": "module",
  "scripts": {
    "validate": "tsx scripts/validate-tree.ts && tsx scripts/validate-content.ts",
    "build": "tsx scripts/validate-tree.ts && tsx scripts/validate-content.ts && tsx scripts/generate-tree.ts && tsx scripts/generate-manifest.ts",
    "generate:tree": "tsx scripts/generate-tree.ts",
    "generate:manifest": "tsx scripts/generate-manifest.ts",
    "validate:tree": "tsx scripts/validate-tree.ts",
    "validate:content": "tsx scripts/validate-content.ts",
    "site:dev": "vite --config site/vite.config.ts",
    "site:build": "vite build --config site/vite.config.ts",
    "site:preview": "vite preview --config site/vite.config.ts"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "glob": "^11.0.0",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "d3": "^7.9.0",
    "@types/d3": "^7.4.0",
    "dompurify": "^3.1.0",
    "@types/dompurify": "^3.0.0",
    "marked": "^12.0.0",
    "mermaid": "^10.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0"
  }
}
